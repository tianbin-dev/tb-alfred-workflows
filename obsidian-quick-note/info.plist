	<key>disabled</key>
	<false/>
	<key>name</key>
	<string>Obsidian Quick Note</string>
	<key>objects</key>
	<array>
		<dict>
			<key>config</key>
			<dict>
				<key>argumenttype</key>
				<integer>1</integer>
				<key>keyword</key>
				<string>on</string>
				<key>subtext</key>
				<string>输入内容，快速记录到 Obsidian 收件箱</string>
				<key>text</key>
				<string>Obsidian Quick Note</string>
				<key>withspace</key>
